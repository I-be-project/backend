# ─── App ──────────────────────────────────────────
APP_ENV=local
APP_BASE_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

# ─── DB ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ─── Storage (Supabase) ───────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET_PHOTOS=photos
STORAGE_BUCKET_CARDS=cards

# ─── Auth ─────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_CARD_SHARE_SECRET=change-me-share
JWT_ISSUER=nabe
STUDENT_TOKEN_TTL_HOURS=6
OPERATOR_TOKEN_TTL_HOURS=12
SHARE_LINK_TTL_HOURS=24

# ─── AI: Chat (OpenAI 호환) ───────────────────────
AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
AI_CHAT_API_KEY=
AI_MODEL_ANALYZE=openai/gpt-5-mini
AI_MODEL_ADAPTIVE_QUESTIONS=openai/gpt-5-mini
AI_MODEL_FINAL_QUESTION=openai/gpt-5.2
AI_MODEL_PERSONA=openai/gpt-5.2
AI_MODEL_IMAGE_PROMPT=openai/gpt-5-mini

# ─── AI: Image ────────────────────────────────────
# 개발 단계: Mindlogic (테스트용 외부 게이트웨이)
# 운영 단계: OpenRouter로 전환 — 아래 3줄만 교체
#   AI_IMAGE_API_URL=https://openrouter.ai/api/v1/images/generations
#   AI_IMAGE_MODEL=openai/gpt-image-1
#   AI_IMAGE_RESPONSE_FORMAT=b64_json
AI_IMAGE_API_URL=https://factchat-cloud.mindlogic.ai/v1/api/openai/images/generate
AI_IMAGE_API_KEY=
AI_IMAGE_MODEL=gpt-image-1
AI_IMAGE_SIZE=1024x1024
# Mindlogic은 빈 값 유지 (기본 b64 반환). OpenRouter는 "b64_json" 명시.
AI_IMAGE_RESPONSE_FORMAT=
AI_IMAGE_TIMEOUT_SECONDS=60
IMAGE_CONCURRENCY=10

# ─── Worker ───────────────────────────────────────
CARD_WORKER_ENABLED=true
CARD_WORKER_CONCURRENCY=10
JOB_POLL_INTERVAL_SECONDS=1
JOB_MAX_RETRIES=2
JOB_STUCK_TIMEOUT_MINUTES=10
