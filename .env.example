# ============================================================
#  .env 예시 — 실제 .env엔 "기본값과 다른 것 + 시크릿"만 두면 됨.
#  (모든 기본값은 app/config.py의 Settings에 정의)
# ============================================================

# ─── 필수: 채워야 하는 값 ──────────────────────────
# OpenRouter 키 하나로 chat·image 모두 사용
AI_API_KEY=

# AWS S3 (단일 비공개 버킷). 버킷은 "모든 퍼블릭 액세스 차단", 노출은 Presigned URL만.
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DB. Supabase 직접 연결(:5432). 트랜잭션 풀러(:6543) 금지.
DATABASE_ENABLED=true
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres

# 운영 배포 시 반드시 실제 랜덤값으로 교체 (openssl rand -hex 32)
JWT_SECRET=change-me-in-production
JWT_CARD_SHARE_SECRET=change-me-share


# ─── 선택: 기본값 있음. 바꿀 때만 주석 해제 ─────────
# --- App ---
# APP_ENV=local                # local | staging | production
# APP_BASE_URL=http://localhost:8000
# FRONTEND_ORIGIN=http://localhost:3000
# LOG_LEVEL=INFO

# --- Storage 프리픽스 ---
# S3_REGION=ap-northeast-2
# STORAGE_PREFIX_UPLOADS=uploads        # 원본 사진
# STORAGE_PREFIX_AI_IMAGES=ai-images    # AI 생성 인물
# STORAGE_PREFIX_CARDS=cards            # 최종 카드
# SUPABASE_URL=                         # DB·Auth 맥락에서만(스토리지는 S3)
# SUPABASE_SERVICE_KEY=

# --- Auth ---
# JWT_ISSUER=ibe
# STUDENT_TOKEN_TTL_HOURS=6
# OPERATOR_TOKEN_TTL_HOURS=12
# SHARE_LINK_TTL_HOURS=24

# --- AI: Chat ---
# AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL_ANALYZE=openai/gpt-5-mini
# AI_MODEL_ADAPTIVE_QUESTIONS=openai/gpt-5-mini
# AI_MODEL_FINAL_QUESTION=openai/gpt-5.2
# AI_MODEL_PERSONA=openai/gpt-5.2
# AI_MODEL_IMAGE_PROMPT=openai/gpt-5-mini

# --- AI: Image (OpenRouter, /chat/completions 단일 엔드포인트) ---
# AI_IMAGE_API_URL=https://openrouter.ai/api/v1/chat/completions
# AI_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
# AI_IMAGE_SIZE=1024x1024               # aspect_ratio 변환 기본값
# AI_IMAGE_STRENGTH=0.5                 # 얼굴 보존 강도(낮을수록 원본에 가까움)
# AI_IMAGE_QUALITY=2K                   # ""(기본)|0.5K|1K|2K|4K
# AI_IMAGE_TIMEOUT_SECONDS=60
# IMAGE_CONCURRENCY=10
# AI_IMAGE_MAX_RETRIES=2                # 총 시도 = 값 + 1
# AI_IMAGE_RETRY_BASE_DELAY=0.5

# --- Worker ---
# CARD_WORKER_ENABLED=true
# CARD_WORKER_CONCURRENCY=10
# JOB_POLL_INTERVAL_SECONDS=1
# JOB_MAX_RETRIES=2
# JOB_STUCK_TIMEOUT_MINUTES=10
