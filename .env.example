# ─── App ──────────────────────────────────────────
APP_ENV=local
APP_BASE_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

# ─── DB ───────────────────────────────────────────
# false면 DB 풀·카드 워커를 건너뜀 (이미지/카드 단독 테스트 시 유용).
DATABASE_ENABLED=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ─── Storage (Supabase) ───────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET_PHOTOS=photos
STORAGE_BUCKET_CARDS=cards

# ─── Auth ─────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_CARD_SHARE_SECRET=change-me-share
JWT_ISSUER=ibe
STUDENT_TOKEN_TTL_HOURS=6
OPERATOR_TOKEN_TTL_HOURS=12
SHARE_LINK_TTL_HOURS=24

# ─── AI: Chat (OpenRouter, OpenAI 호환) ───────────
AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter 키 하나로 chat·image 모두 사용
AI_API_KEY=
AI_MODEL_ANALYZE=openai/gpt-5-mini
AI_MODEL_ADAPTIVE_QUESTIONS=openai/gpt-5-mini
AI_MODEL_FINAL_QUESTION=openai/gpt-5.2
AI_MODEL_PERSONA=openai/gpt-5.2
AI_MODEL_IMAGE_PROMPT=openai/gpt-5-mini

# ─── AI: Image (OpenRouter) ───────────────────────
# OpenRouter는 이미지 생성·편집을 /chat/completions 한 엔드포인트로 처리한다
# (modalities + image_config). 키는 Chat과 동일한 OpenRouter 키.
AI_IMAGE_API_URL=https://openrouter.ai/api/v1/chat/completions
# 이미지 모델: google/gemini-2.5-flash-image (Nano Banana, 얼굴 유지 image-to-image).
#   더 좋은 화질: google/gemini-3.1-flash-image-preview
AI_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
# size는 aspect_ratio 변환 기본값 (예: 1024x1536 → 2:3). 파이프라인이 보통 명시 전달.
AI_IMAGE_SIZE=1024x1024
# 얼굴 입력 보존 강도 (0.0~1.0, 낮을수록 원본에 가까움)
AI_IMAGE_STRENGTH=0.5
# 출력 해상도 (모델 지원 시): ""(기본)|0.5K|1K|2K|4K. gemini-3.1-flash-image-preview만 확실 지원
AI_IMAGE_QUALITY=2K
AI_IMAGE_TIMEOUT_SECONDS=60
IMAGE_CONCURRENCY=10
# 일시적 실패(타임아웃·429·5xx·손상응답) 재시도. 총 시도 = MAX_RETRIES + 1.
AI_IMAGE_MAX_RETRIES=2
AI_IMAGE_RETRY_BASE_DELAY=0.5

# ─── Worker ───────────────────────────────────────
CARD_WORKER_ENABLED=true
CARD_WORKER_CONCURRENCY=10
JOB_POLL_INTERVAL_SECONDS=1
JOB_MAX_RETRIES=2
JOB_STUCK_TIMEOUT_MINUTES=10
